# 服务器配置
APP_SERVER_PORT=8080
APP_SERVER_MODE=debug

# 数据库配置
APP_DATABASE_HOST=localhost
APP_DATABASE_PORT=5432
APP_DATABASE_NAME=kiqi
APP_DATABASE_USER=postgres
APP_DATABASE_PASSWORD=
APP_DATABASE_SSL_MODE=disable

# Redis配置
APP_REDIS_ADDR=localhost:6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0

# JWT配置
APP_JWT_SECRET=your-jwt-secret-key-change-in-production
APP_JWT_ACCESS_EXPIRE=30m
APP_JWT_REFRESH_EXPIRE=7d

# 日志配置
APP_LOGGING_LEVEL=debug
APP_LOGGING_FORMAT=console

# 加密配置（AES-256-GCM，用于敏感字段加密，至少 32 字符）
APP_ENCRYPTION_KEY=your-encryption-key-change-in-production